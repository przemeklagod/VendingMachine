<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvCardLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Card number"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCardNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:text="-"
        android:textSize="20sp" />

    <EditText
        android:id="@+id/etCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Enter selection code (e.g. 2, 38, 57)"
        android:inputType="number"
        android:focusable="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnModeLocker"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Locker" />

        <Button
            android:id="@+id/btnModeSpiral"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Spiral" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSelectionHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Selection examples: A00=2, A02=4, A04=6, D00=38, D01=37, F01=57, F02=56"
        android:textColor="#666666"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDiagFw"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="FW" />

        <Button
            android:id="@+id/btnDiagStatus"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="STATUS" />

        <Button
            android:id="@+id/btnDiagProbe"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="PROBE" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ready" />

    <TextView
        android:id="@+id/tvTelemetryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Telemetry"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTelemetryFw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FW: -" />

    <TextView
        android:id="@+id/tvTelemetryStatus47"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0x47: -" />

    <TextView
        android:id="@+id/tvTelemetrySensor44"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0x44: -" />

    <TextView
        android:id="@+id/tvTelemetryTelemetry4a"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0x4A: -" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:columnCount="3">

        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="1" />
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="2" />
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="3" />

        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="4" />
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="5" />
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="6" />

        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="7" />
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="8" />
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="9" />

        <Button android:id="@+id/btnClear" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="CLR" />
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="0" />
        <Button android:id="@+id/btnBack" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="DEL" />
    </GridLayout>

    <Button
        android:id="@+id/btnEnter"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="ENTER" />

</LinearLayout>
